# ─────────────────────────────────────────────────────────────────────────────
# Autodesk Platform Services (APS) 設定
# https://aps.autodesk.com/ でアプリを作成して取得
# ─────────────────────────────────────────────────────────────────────────────

# サーバーサイド（秘匿情報 - NEXT_PUBLIC_ を付けない）
APS_CLIENT_ID=your_client_id_here
APS_CLIENT_SECRET=your_client_secret_here

# 表示するモデルの URN（Base64エンコード済み）
# モデルを APS に Upload → Translate した後に取得できる
MODEL_URN=dXJuOmFkc2sub2JqZWN0czpvcy5...
